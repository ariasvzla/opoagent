{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Build and Run Backend",
      "type": "shell",
      "command": "bash -lc 'docker build -t deepagent . && docker run --name deepagent --rm -p 8000:8000 --env-file .env deepagent'",
      "problemMatcher": {
        "owner": "docker",
        "severity": "error",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "file": 1
      },
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Docker: Stop Backend",
      "type": "shell",
      "command": "bash -lc 'docker rm -f deepagent >/dev/null 2>&1 || true'",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Start Vite",
      "type": "shell",
      "command": "bash -lc 'cd frontend && npm run dev'",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Stop Vite",
      "type": "shell",
      "command": "bash -lc 'pkill -f \\\"npm run dev\\\" >/dev/null 2>&1 || pkill -f vite >/dev/null 2>&1 || true'",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
